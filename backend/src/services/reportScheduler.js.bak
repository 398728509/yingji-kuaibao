const EventModel = require('../models/Event');
const ReportModel = require('../models/Report');
const { generateReport } = require('./reportGenerator');
const { broadcast } = require('../websocket');

// 存储定时器
const timers = new Map();

/**
 * 为每个活跃事件启动10分钟周期调度
 */
function startCycleForEvent(eventId) {
  if (timers.has(eventId)) return;

  console.log(`⏱ 启动10分钟生成周期 - 事件 ${eventId}`);

  // 首次：立即生成一版
  try {
    const report = generateReport(eventId);
    console.log(`  首版快报已生成 (v${report.version})`);
  } catch (e) {
    // 无素材时跳过
  }

  // 每10分钟生成
  const timer = setInterval(() => {
    try {
      const event = EventModel.getById(eventId);
      if (!event || event.status !== 'active') {
        stopCycleForEvent(eventId);
        return;
      }

      // 检查自上次快报以来是否有新素材
      const lastReport = ReportModel.getLatestByEvent(eventId);
      const MaterialModel = require('../models/Material');
      let hasNewMaterial = true;
      if (lastReport) {
        const newCount = MaterialModel.countNewSince(eventId, lastReport.created_at);
        hasNewMaterial = newCount > 0;
      }
      if (!hasNewMaterial) {
        console.log('⏱ 事件', eventId, '无新素材，跳过生成');
        return;
      }
      const report = generateReport(eventId);
      console.log(`  ⏱ 快报已生成 - 事件 ${eventId} v${report.version}`);

      broadcast({
        type: 'cycle_report',
        eventId,
        reportId: report.id,
        version: report.version,
        summary: report.summary,
        diffNotes: report.diff_notes,
        generatedAt: report.created_at
      });
    } catch (err) {
      console.error(`  快报生成失败:`, err.message);
    }
  }, 10 * 60 * 1000); // 10分钟

  timers.set(eventId, timer);
}

/**
 * 停止事件周期
 */
function stopCycleForEvent(eventId) {
  if (timers.has(eventId)) {
    clearInterval(timers.get(eventId));
    timers.delete(eventId);
    console.log(`⏱ 停止生成周期 - 事件 ${eventId}`);
  }
}

/**
 * 停止所有周期
 */
function stopAllCycles() {
  for (const [eventId, timer] of timers) {
    clearInterval(timer);
  }
  timers.clear();
  console.log('⏱ 已停止所有生成周期');
}

/**
 * 初始化：为所有活跃事件启动周期
 */
function initCycles() {
  const events = EventModel.getActiveEvents();
  for (const event of events) {
    startCycleForEvent(event.id);
  }
  console.log(`⏱ 已为 ${events.length} 个活跃事件启动生成周期`);
}

module.exports = {
  startCycleForEvent,
  stopCycleForEvent,
  stopAllCycles,
  initCycles
};
